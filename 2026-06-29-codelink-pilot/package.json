{
  "name": "codelink-pilot",
  "version": "1.0.0",
  "description": "Web‑only PWA cockpit that lets AI coding agents edit files in a sandboxed virtual filesystem with live previews and a WebAssembly PTY.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "test": "jest --coverage",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asmit25805/codelink-pilot.git"
  },
  "keywords": [
    "pwa",
    "virtual-fs",
    "wasm-pty",
    "ai-agent",
    "typescript"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "browserfs": "^1.7.3",
    "xterm": "^5.2.0",
    "wasm-pty": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.48.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.2",
    "rimraf": "^5.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
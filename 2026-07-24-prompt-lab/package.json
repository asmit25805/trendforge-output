{
  "name": "prompt-lab",
  "version": "1.0.0",
  "description": "In-browser playground that turns prompt metadata into runnable React + Tailwind previews",
  "type": "module",
  "main": "dist/cli/main.js",
  "types": "dist/types.d.ts",
  "scripts": {
    "build": "tsc && esbuild src/compiler/sandboxCompiler.ts --bundle --platform=node --outfile=dist/compiler/sandboxCompiler.js",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.2",
    "zod": "^3.22.4",
    "react-query": "^3.39.3"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "esbuild": "^0.19.4",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.2",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "ts-jest": "^29.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asmit25805/prompt-lab.git"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}